# ─── Application ───────────────────────────────────────────────────────────────
ENV=development
SERVER__HOST=0.0.0.0
SERVER__PORT=8080


# ---- CORS ─────────────────────────────────────────────────────────────────────
CORS__ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS__ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE
CORS__ALLOWED_HEADERS=Authorization,Content-Type


# ---- Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT__REQUESTS=100
RATE_LIMIT__WINDOW_SECS=60


# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE__URL=postgres://postgres:password@localhost:5432/myapp_db
DATABASE__MAX_CONNECTIONS=10
DATABASE__MIN_CONNECTIONS=2
DATABASE__CONNECT_TIMEOUT_SECS=5
DATABASE__LOG_SLOW_QUERIES=true


# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT__ACCESS_TOKEN=change_me_to_a_long_random_secret_at_least_64_chars_in_production
JWT__ACCESS_TOKEN_EXPIRY_SECS=900
JWT__REFRESH_TOKEN=change_me_to_a_long_random_secret_at_least_64_chars_in_production
JWT__REFRESH_TOKEN_EXPIRY_SECS=2592000


# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS__URL=redis://localhost:6379
REDIS__POOL_SIZE=10
REDIS__TTL_DEFAULT_SECS=3600


# ─── Tracing ───────────────────────────────────────────────────────────────────
RUST__LOG=info,sqlx=warn,hyper=warn


# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP__FROM_NAME=MyApp
SMTP__FROM_EMAIL=no-reply@example.com
SMTP__HOST=smtp.example.com
SMTP__PORT=587
SMTP__USERNAME=no-reply@example.com
SMTP__PASSWORD=your_smtp_password


# ---- File Storage ──────────────────────────────────────────────────────────────
STORAGE__DRIVER=local
STORAGE__LOCAL_PATH=./uploads
# or
STORAGE__S3_BUCKET=my-bucket
STORAGE__S3_REGION=ap-southeast-1


# ---- External API ──────────────────────────────────────────────────────────────
THIRD_PARTY__API_URL=https://api.example.com
THIRD_PARTY__API_KEY=secret_key

