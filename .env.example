# ─── Application ───────────────────────────────────────────────────────────────
ENV=development
# SERVER__HOST=0.0.0.0
SERVER__PORT=8080

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE__URL=postgres://postgres:password@localhost:5432/myapp_db
DATABASE__MAX_CONNECTIONS=10

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT__SECRET=change_me_to_a_long_random_secret_at_least_64_chars_in_production
JWT__ACCESS_TOKEN_EXPIRY_SECS=900
JWT__REFRESH_TOKEN_EXPIRY_SECS=2592000

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS__URL=redis://localhost:6379

# ─── Tracing ───────────────────────────────────────────────────────────────────
RUST_LOG=info,sqlx=warn,hyper=warn

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=no-reply@example.com
# SMTP_PASSWORD=your_smtp_password
